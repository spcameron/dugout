# Example environment configuration for Dugout
# Copy this file to `.env` and update values as needed.

# PostgreSQL settings
POSTGRES_USER=dugout_user
POSTGRES_PASSWORD=dugout_pass
POSTGRES_DB=dugout_dev

# Full connection URL used by the application
# The above values should match the components here.
DB_URL=postgres://dugout_user:dugout_pass@localhost:5432/dugout_dev?sslmode=disable

